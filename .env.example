# Backend Selection
# docker        — Hermes in a Docker container on a remote SSH host (default, fully supported)
# baremetal-ssh — Hermes running natively on a remote SSH host (stub, PRs welcome)
# local         — Hermes running on this machine, no SSH (stub, PRs welcome)
HERMES_BACKEND=docker

# SSH / Remote Host
HERMES_SSH_HOST=user@your-hermes-host   # user@hostname or just hostname if SSH config handles the user
HERMES_SSH_PORT=22
HERMES_SSH_KEY_PATH=~/.ssh/id_ed25519

# Docker Configuration
HERMES_CONTAINER_NAME=hermes-sandbox
HERMES_DOCKER_BIN=/opt/homebrew/bin/docker   # macOS default; Linux: /usr/bin/docker or just "docker"
HERMES_DOCKER_COMPOSE_FILE=docker-compose.hermes-hardened.yml

# Hermes Binary (path inside the container for Docker; path on remote host for baremetal-ssh)
HERMES_BINARY=/opt/hermes/.venv/bin/hermes

# Write-safe root — the path Hermes is allowed to write files to in the environment
# Set this to match HERMES_WRITE_SAFE_ROOT in the container / host config
HERMES_WRITE_SAFE_ROOT=/app/sandbox

# Model Configuration
#
# Option 1: Local Ollama (slow, ~4-5 min per query)
# HERMES_MODEL=qwen3-4b-hermes-64k:latest
# HERMES_PROVIDER=ollama
# HERMES_BASE_URL=http://host.docker.internal:11434/v1
#
# Option 2: OpenRouter (RECOMMENDED for testing - fast, ~10-30s per query)
HERMES_PROVIDER=openrouter
HERMES_MODEL=qwen/qwen-2.5-7b-instruct
# Set HERMES_API_KEY via environment variable (never commit API keys):
#   export HERMES_API_KEY="sk-or-v1-..."

# Test Configuration
HERMES_TEST_TIMEOUT=120  # seconds
HERMES_TOOL_RESTRICTIONS=terminal,file,code_execution,web,browser
HERMES_LOG_LEVEL=INFO

# Verification Configuration
HERMES_VERIFY_SSH_HOST=user@your-hermes-host  # Used for side-effect verification
HERMES_TEST_FILE_PATH=/tmp/hermes-test-suite

# DeepEval Configuration
DEEPEVAL_API_KEY=  # Optional: for LLM-as-judge scoring
DEEPEVAL_GENERATE_REPORT=true

# Optional: Computer Use Testing (requires explicit opt-in)
# Uncomment only when running tests with --computer-use flag
# HERMES_COMPUTER_USE_ENABLED=true
