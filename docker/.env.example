# =============================================================================
# Hermes Evaluation — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in all values before running docker compose.
# Never commit .env to version control (it's in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Discord bot token
# Get from: https://discord.com/developers/applications → Your App → Bot → Token
# Reset this token immediately if it is ever exposed in logs or shared files.
# -----------------------------------------------------------------------------
DISCORD_TOKEN=your_discord_bot_token_here

# -----------------------------------------------------------------------------
# Discord user allowlist
# Comma-separated list of Discord user IDs (not usernames) who are permitted
# to invoke Hermes commands. All other users are silently ignored.
#
# How to get a user ID:
#   1. Enable Developer Mode in Discord: Settings → Advanced → Developer Mode
#   2. Right-click any user → "Copy User ID"
#
# Example (multiple users):
#   DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432
# -----------------------------------------------------------------------------
DISCORD_ALLOWED_USERS=comma_separated_discord_user_ids

# -----------------------------------------------------------------------------
# Dedicated Anthropic API key for Hermes ONLY
#
# This MUST be a separate key from any other Anthropic key in use on this host.
# Reasons:
#   - Eval billing is isolated: easy to audit Hermes's API spend independently
#   - If this key is compromised, revoke it without affecting other services
#   - Rate limits on this key only affect Hermes, not other workloads
#
# Create a new key at: https://console.anthropic.com/settings/keys
# Name it something identifiable, e.g. "hermes-eval"
#
# Note: Hermes defaults to llama3.1:8b via Ollama and only falls back to
# Anthropic if explicitly configured with --provider anthropic. This key
# is present for that fallback and for future eval phases.
# -----------------------------------------------------------------------------
HERMES_ANTHROPIC_API_KEY=sk-ant-...dedicated_key_for_hermes_only...
